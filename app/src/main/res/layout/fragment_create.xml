<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/cm_dp_16"
            android:layout_weight="1"
            android:fontFamily="@string/roboto_bold"
            android:textStyle="bold"
            android:gravity="start|center_vertical"
            android:text="@string/tab_create_toolbar"
            android:textColor="#031C36"
            android:textSize="@dimen/cm_sp_20" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_delete"
            android:layout_width="?attr/actionBarSize"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:scaleType="center"
            android:visibility="gone"
            app:srcCompat="@drawable/vector_ic_delete" />
    </LinearLayout>

    <View
        android:id="@+id/view_divider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cm_dp_2"
        android:alpha="0.2"
        android:background="@drawable/shape_divider_bottom"
        app:layout_constraintTop_toBottomOf="@id/ll_top_bar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_creat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/cm_dp_48"
        android:background="#F5F6FA"
        app:layout_constraintBottom_toBottomOf="parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/cm_dp_20"
        app:layout_constraintTop_toBottomOf="@id/view_divider" />


</androidx.constraintlayout.widget.ConstraintLayout>