<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_creat_result_white"
    android:paddingTop="@dimen/cm_dp_20"
    android:paddingBottom="@dimen/cm_dp_25">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_icon"
        android:layout_width="@dimen/cm_dp_64"
        android:layout_height="@dimen/cm_dp_64"
        android:layout_gravity="center_horizontal"
        android:background="@color/white"
        android:padding="@dimen/cm_dp_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/vector_ic_twitter" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@string/roboto_regular"
        android:gravity="center"
        android:padding="@dimen/cm_dp_7"
        android:text="Clipboard"
        android:textColor="#ff0b1430"
        android:textSize="@dimen/cm_sp_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_icon" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_open"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_creat_input_open"
        android:gravity="center"
        android:text="@string/action_open"
        android:paddingVertical="@dimen/cm_dp_3"
        android:paddingHorizontal="@dimen/cm_dp_14"
        android:textColor="#007AFF"
        android:textSize="@dimen/cm_sp_13"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:textAllCaps="true" />

</androidx.constraintlayout.widget.ConstraintLayout>