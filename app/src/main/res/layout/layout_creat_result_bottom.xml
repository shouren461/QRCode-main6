<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btu_save"
        android:layout_width="0dp"
        android:layout_height="@dimen/cm_dp_60"
        android:layout_marginTop="@dimen/cm_dp_10"
        android:background="@drawable/shape_create_result_btu_bg_share"
        android:fontFamily="@string/roboto_medium"
        android:text="@string/save"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="@dimen/cm_sp_18"
        android:layout_marginEnd="@dimen/cm_dp_8"
        android:layout_marginBottom="@dimen/cm_dp_10"
        app:layout_constraintEnd_toStartOf="@id/btu_share"
        app:layout_constraintStart_toStartOf="parent"
        tools:elevation="@dimen/cm_dp_20"
        tools:foreground="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btu_share"
        android:layout_width="0dp"
        android:layout_height="@dimen/cm_dp_60"
        android:layout_marginStart="@dimen/cm_dp_8"
        android:background="@drawable/shape_create_result_btu_bg_share"
        android:layout_marginTop="@dimen/cm_dp_10"
        android:fontFamily="@string/roboto_medium"
        android:text="@string/button_share"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:layout_marginBottom="@dimen/cm_dp_10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btu_save"
        tools:elevation="@dimen/cm_dp_20"
        android:textSize="@dimen/cm_sp_18"
        tools:foreground="?attr/selectableItemBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>