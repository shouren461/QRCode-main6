<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    android:paddingTop="@dimen/cm_dp_24">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_icon"
        android:layout_width="@dimen/cm_dp_64"
        android:layout_height="@dimen/cm_dp_64"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_creat_item"
        android:padding="@dimen/cm_dp_18"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/vector_ic_twitter" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@string/roboto_medium"
        android:gravity="center"
        android:paddingStart="@dimen/cm_dp_8"
        android:paddingTop="@dimen/cm_dp_8"
        android:paddingEnd="@dimen/cm_dp_8"
        android:text="Clipboard"
        android:textColor="#ff0b1430"
        android:textSize="@dimen/cm_sp_14"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_icon" />

</androidx.constraintlayout.widget.ConstraintLayout>