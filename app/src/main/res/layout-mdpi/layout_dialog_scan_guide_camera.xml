<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/main"
    android:background="@drawable/bg_corner_16_top">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.075"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.925"/>

    <Space
        android:id="@+id/space_1"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cm_dp_30"
        app:layout_constraintBottom_toTopOf="@id/tv_title"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@string/roboto_medium"
        android:text="@string/point_your_camera"
        android:textColor="#333333"
        android:textSize="@dimen/cm_sp_26"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/space_2"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintTop_toBottomOf="@id/space_1"
        app:layout_constraintWidth_percent="0.817" />

    <Space
        android:id="@+id/space_2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cm_dp_20"
        app:layout_constraintBottom_toTopOf="@id/tv_subtitle_1"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintVertical_weight="26" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_subtitle_1_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1."
        android:textColor="#333333"
        android:textSize="@dimen/cm_sp_15"
        android:fontFamily="@string/roboto_regular"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintTop_toTopOf="@id/tv_subtitle_1"
        tools:ignore="HardcodedText" />
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_subtitle_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="@dimen/cm_sp_15"
        android:fontFamily="@string/roboto_regular"
        app:layout_constraintBottom_toTopOf="@id/tv_subtitle_2"
        app:layout_constraintStart_toEndOf="@id/tv_subtitle_1_num"
        app:layout_constraintTop_toBottomOf="@id/space_2"
        app:layout_constraintEnd_toEndOf="@id/guideline_end"
        tools:text="@string/avoid_reflections" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_subtitle_2_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2."
        android:textColor="#333333"
        android:textSize="@dimen/cm_sp_15"
        android:fontFamily="@string/roboto_regular"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintTop_toTopOf="@id/tv_subtitle_2"
        tools:ignore="HardcodedText" />
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_subtitle_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="@dimen/cm_sp_15"
        android:fontFamily="@string/roboto_regular"
        app:layout_constraintBottom_toTopOf="@id/space_3"
        app:layout_constraintStart_toEndOf="@id/tv_subtitle_2_num"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle_1"
        app:layout_constraintEnd_toEndOf="@id/guideline_end"
        tools:text="@string/make_phone_face" />

    <Space
        android:id="@+id/space_3"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cm_dp_19"
        app:layout_constraintBottom_toTopOf="@id/iv"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle_2" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/space_4"
        app:layout_constraintEnd_toStartOf="@id/iv_2"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintTop_toBottomOf="@id/space_3"
        app:srcCompat="@drawable/img_errorqr" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/iv"
        app:layout_constraintEnd_toEndOf="@id/guideline_end"
        app:layout_constraintStart_toEndOf="@id/iv"
        app:layout_constraintTop_toTopOf="@id/iv"
        app:srcCompat="@drawable/img_correctqr" />

    <Space
        android:id="@+id/space_4"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cm_dp_12"
        app:layout_constraintBottom_toTopOf="@id/tv_positive"
        app:layout_constraintTop_toBottomOf="@id/iv" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_positive"
        android:layout_width="0dp"
        android:layout_height="@dimen/cm_dp_60"
        android:background="@drawable/bg_button_state_enable"
        android:fontFamily="@string/roboto_medium"
        android:gravity="center"
        android:text="@string/start"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/cm_sp_20"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/space_5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/space_4"
        app:layout_constraintWidth_percent="0.8" />

    <Space
        android:id="@+id/space_5"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cm_dp_30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_positive" />

</androidx.constraintlayout.widget.ConstraintLayout>