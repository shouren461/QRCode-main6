<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_bottom">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="@dimen/qr_dp_35"
        android:paddingBottom="@dimen/qr_dp_35">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_smile"
            android:layout_width="@dimen/qr_dp_66"
            android:layout_height="@dimen/qr_dp_66"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/png_ask_smile" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_description"
            style="@style/FontBlack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/qr_dp_16"
            android:gravity="center"
            android:text="@string/satisfied_scan_ask"
            android:textColor="@color/dialog_text_first"
            android:textSize="@dimen/qr_sp_22"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_smile"
            app:layout_constraintWidth_percent="0.85" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_positive"
            style="@style/FontBlack"
            android:layout_width="0dp"
            android:layout_height="@dimen/qr_dp_50"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_ripple_corner_12"
            android:backgroundTint="@color/themeColor"
            android:gravity="center"
            android:text="@string/good"
            android:textColor="@color/dialog_text_button_positive"
            android:textSize="@dimen/qr_sp_16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:layout_constraintWidth_percent="0.8" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_negative"
            style="@style/FontBlack"
            android:layout_width="0dp"
            android:layout_height="@dimen/qr_dp_50"
            android:layout_marginTop="@dimen/qr_dp_18"
            android:background="@drawable/bg_ripple_corner_12"
            android:backgroundTint="@color/themeColor"
            android:gravity="center"
            android:text="@string/not_good"
            android:textColor="@color/dialog_text_button_positive"
            android:textSize="@dimen/qr_sp_16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_positive"
            app:layout_constraintWidth_percent="0.8" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>