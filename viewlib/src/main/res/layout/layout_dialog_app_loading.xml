<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="@dimen/qr_dp_96"
        android:background="@drawable/bg_dialog"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.53">

        <ProgressBar
            android:layout_width="@dimen/qr_dp_40"
            android:layout_height="@dimen/qr_dp_40" />

        <androidx.appcompat.widget.AppCompatTextView
            style="@style/FontBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/qr_dp_8"
            android:text="@string/loading"
            android:textColor="@color/dialog_text_second"
            android:textSize="@dimen/qr_sp_14" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>



