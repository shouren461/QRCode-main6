<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:gravity="bottom"
        tools:layout_gravity="center_horizontal"
        android:paddingHorizontal="@dimen/qr_dp_10"
        tools:ignore="UselessParent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_dialog"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_capture"
                style="@style/FontBold"
                android:layout_width="match_parent"
                android:layout_height="@dimen/qr_dp_60"
                android:background="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/capture"
                android:textColor="@color/dialog_text_first" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1e000000" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_gallery"
                style="@style/FontBold"
                android:layout_width="match_parent"
                android:layout_height="@dimen/qr_dp_60"
                android:background="?attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/browse_from_gallery"
                android:textColor="@color/dialog_text_first" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/qr_dp_8"
            android:background="#1e000000" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_cancel"
            style="@style/FontBold"
            android:layout_width="match_parent"
            android:layout_height="@dimen/qr_dp_60"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/qr_dp_18"
            android:background="@drawable/bg_dialog"
            android:gravity="center"
            android:text="@string/fb_button_cancel"
            android:textColor="@color/dialog_text_first" />
    </LinearLayout>
</LinearLayout>