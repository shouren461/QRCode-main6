<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_bottom"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qr_dp_30"
        android:orientation="vertical"
        android:paddingBottom="@dimen/qr_dp_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.9">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_guide_title"
            style="@style/FontBlack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scan_image_title"
            android:textColor="@color/dialog_text_first"
            android:textSize="@dimen/qr_sp_24" />

        <LinearLayout
            android:id="@+id/ll_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/qr_dp_33">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_guide_1"
                style="@style/FontBlack"
                android:layout_width="@dimen/qr_dp_26"
                android:layout_height="@dimen/qr_dp_26"
                android:background="@drawable/bg_corner_5"
                android:backgroundTint="@color/themeColor"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="@dimen/qr_sp_15"
                tools:ignore="HardcodedText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_guide_content_1"
                style="@style/FontBlack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/qr_dp_16"
                android:text="@string/scan_image_how_to_1"
                android:textColor="@color/dialog_text_second"
                android:textSize="@dimen/qr_sp_15" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/qr_dp_28"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_guide_2"
                style="@style/FontBlack"
                android:layout_width="@dimen/qr_dp_26"
                android:layout_height="@dimen/qr_dp_26"
                android:background="@drawable/bg_corner_5"
                android:backgroundTint="@color/themeColor"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="@dimen/qr_sp_15"
                tools:ignore="HardcodedText" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_guide_content_2"
                style="@style/FontBlack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/qr_dp_16"
                android:text="@string/scan_image_how_to_2"
                android:textColor="@color/dialog_text_second"
                android:textSize="@dimen/qr_sp_15" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_positive"
            style="@style/FontBlack"
            android:layout_width="match_parent"
            android:layout_height="@dimen/qr_dp_50"
            android:layout_marginTop="@dimen/qr_dp_50"
            android:background="@drawable/bg_ripple_corner_12"
            android:backgroundTint="@color/themeColor"
            android:gravity="center"
            android:text="@string/action_ok"
            android:textColor="@color/dialog_text_first"
            android:textSize="@dimen/qr_sp_16"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_2"
            app:layout_constraintVertical_bias="0.0" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>