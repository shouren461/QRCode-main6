<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_bottom"
    android:orientation="vertical"
    android:theme="@style/WebViewTheme"
    tools:layout_gravity="bottom">


    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_logo"
        android:layout_width="@dimen/qr_dp_54"
        android:layout_height="@dimen/qr_dp_54"
        android:layout_marginTop="@dimen/qr_dp_30"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/svg_google_play" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_des"
        style="@style/FontBlack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qr_dp_22"
        android:gravity="center"
        android:text="@string/x_link_open"
        android:textColor="@color/dialog_text_first"
        android:textSize="@dimen/qr_sp_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintWidth_percent="0.85" />

    <Space
        android:id="@+id/space_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@id/tv_negative"
        app:layout_constraintHorizontal_weight="16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_negative" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_negative"
        style="@style/FontBlack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qr_dp_38"
        android:background="@drawable/bg_stroke"
        android:gravity="center"
        android:padding="@dimen/qr_dp_15"
        android:text="@string/no"
        android:textColor="@color/themeColor"
        android:textSize="@dimen/qr_sp_16"
        app:layout_constraintEnd_toStartOf="@id/space_2"
        app:layout_constraintHorizontal_weight="159"
        app:layout_constraintStart_toEndOf="@id/space_1"
        app:layout_constraintTop_toBottomOf="@id/tv_des" />

    <Space
        android:id="@+id/space_2"
        style="@style/FontBlack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="@dimen/qr_sp_16"
        app:layout_constraintEnd_toStartOf="@id/tv_positive"
        app:layout_constraintHorizontal_weight="10"
        app:layout_constraintStart_toEndOf="@id/tv_negative"
        app:layout_constraintTop_toTopOf="@id/tv_negative" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_positive"
        style="@style/FontBlack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ripple_corner_12"
        android:backgroundTint="@color/themeColor"
        android:gravity="center"
        android:padding="@dimen/qr_dp_15"
        android:text="@string/parse_action_title_open"
        android:textColor="@color/dialog_text_first"
        android:textSize="@dimen/qr_sp_16"
        app:layout_constraintEnd_toStartOf="@id/space_3"
        app:layout_constraintHorizontal_weight="159"
        app:layout_constraintStart_toEndOf="@id/space_2"
        app:layout_constraintTop_toTopOf="@id/tv_negative" />

    <Space
        android:id="@+id/space_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="16"
        app:layout_constraintStart_toEndOf="@id/tv_positive"
        app:layout_constraintTop_toTopOf="@id/tv_negative" />

    <LinearLayout
        android:id="@+id/ll_ad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qr_dp_26"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_negative"
        tools:layout_height="100dp" />

</androidx.constraintlayout.widget.ConstraintLayout>